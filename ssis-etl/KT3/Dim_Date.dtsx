      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{48255525-DF27-4D39-9F96-F9E61C00D4D5}"
          SQLTask:SqlStatementSource="&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;&#x9;WHERE CONSTRAINT_NAME = 'FK_Fact_Appearances_Dim_Date') -- Menjamo naziv Constraint-a&#xA;&#xA;BEGIN&#xA;&#x9;&#xA;&#x9;ALTER TABLE [dbo].[Fact_Appearances] DROP CONSTRAINT [FK_Fact_Appearances_Dim_Date] -- Menjamo ovu liniju&#xA;END;&#xA;&#xA;&#xA;&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;&#x9;WHERE CONSTRAINT_NAME = 'FK_Fact_Valuations_Dim_Date') -- Menjamo naziv Constraint-a&#xA;&#xA;BEGIN&#xA;&#x9;&#xA;&#x9;ALTER TABLE [dbo].[Fact_Valuations] DROP CONSTRAINT [FK_Fact_Valuations_Dim_Date] -- Menjamo ovu liniju&#xA;END;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM sysobjects&#xA;&#x9;WHERE id = OBJECT_ID(N'Dim_Date')) -- Menjamo naziv tabele&#xA;BEGIN&#xA;&#x9;-- KOMANDA ZA DROP TABLE&#xA;&#x9;IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[Dim_Date]') AND type in (N'U'))&#xA;&#x9;DROP TABLE [dbo].[Dim_Date]&#xA;&#xA;&#xA;&#x9;-- KOMANDA ZA CREATE TABLE&#xA;CREATE TABLE [dbo].[Dim_Date](&#xA;&#x9;[date_sid] [int] NOT NULL,&#xA;&#x9;[year] [int] NOT NULL,&#xA;&#x9;[quarter] [char](2) NOT NULL,&#xA;&#x9;[month] [int] NOT NULL,&#xA;&#x9;[day] [int] NOT NULL,&#xA;&#x9;[season] [varchar](10) NOT NULL,&#xA;PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[date_sid] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Dim_Date]  WITH CHECK ADD  CONSTRAINT [CHK_Date_Quarter] CHECK  (([quarter]='Q4' OR [quarter]='Q3' OR [quarter]='Q2' OR [quarter]='Q1'))&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Dim_Date] CHECK CONSTRAINT [CHK_Date_Quarter]&#xA;&#xA;&#xA;&#xA;END&#xA;&#xA;&#xA;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
