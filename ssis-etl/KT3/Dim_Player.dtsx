      DTS:ObjectName="DROP and CREATE Dim_Player"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{48255525-DF27-4D39-9F96-F9E61C00D4D5}"
          SQLTask:SqlStatementSource="&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;&#x9;WHERE CONSTRAINT_NAME = 'FK_Fact_Appearances_Dim_Player') -- Menjamo naziv Constraint-a&#xA;&#xA;BEGIN&#xA;&#x9;&#xA;&#x9;ALTER TABLE [dbo].[Fact_Appearances] DROP CONSTRAINT [FK_Fact_Appearances_Dim_Player] -- Menjamo ovu liniju&#xA;END;&#xA;&#xA;&#xA;&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;&#x9;WHERE CONSTRAINT_NAME = 'FK_Fact_Valuations_Dim_Player') -- Menjamo naziv Constraint-a&#xA;&#xA;BEGIN&#xA;&#x9;&#xA;&#x9;ALTER TABLE [dbo].[Fact_Valuations] DROP CONSTRAINT [FK_Fact_Valuations_Dim_Player] -- Menjamo ovu liniju&#xA;END;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM sysobjects&#xA;&#x9;WHERE id = OBJECT_ID(N'Dim_Player')) -- Menjamo naziv tabele&#xA;BEGIN&#xA;&#x9;-- KOMANDA ZA DROP TABLE&#xA;&#x9;IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[Dim_Player]') AND type in (N'U'))&#xA;&#x9;DROP TABLE [dbo].[Dim_Player]&#xA;&#xA;&#xA;&#x9;-- KOMANDA ZA CREATE TABLE&#xA;CREATE TABLE [dbo].[Dim_Player](&#xA;&#x9;[player_sid] [int] IDENTITY(1,1) NOT NULL,&#xA;&#x9;[player_id] [int] NULL,&#xA;&#x9;[first_name] [nvarchar](80) NOT NULL,&#xA;&#x9;[last_name] [nvarchar](80) NOT NULL,&#xA;&#x9;[date_of_birth] [date] NULL,&#xA;&#x9;[position_sid] [int] NULL,&#xA;&#x9;[foot] [varchar](10) NULL,&#xA;&#x9;[height_cm] [int] NULL,&#xA;&#x9;[contract_expiration] [date] NULL,&#xA;&#x9;[last_season] [int] NULL,&#xA;PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[player_sid] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Dim_Player]  WITH CHECK ADD  CONSTRAINT [CHK_Player_Height] CHECK  (([height_cm]&gt;=(140) AND [height_cm]&lt;=(230)) OR [height_cm]=(-1))&#xA;&#xA;&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Dim_Player] CHECK CONSTRAINT [CHK_Player_Height]&#xA;&#xA;&#xA;&#xA;END&#xA;&#xA;&#xA;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
