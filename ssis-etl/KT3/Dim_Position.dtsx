      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{48255525-DF27-4D39-9F96-F9E61C00D4D5}"
          SQLTask:SqlStatementSource="&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;&#x9;WHERE CONSTRAINT_NAME = 'FK_Dim_Player_Dim_Position') -- Menjamo naziv Constraint-a&#xA;&#xA;BEGIN&#xA;&#x9;&#xA;&#x9;ALTER TABLE [dbo].[Dim_Player] DROP CONSTRAINT [FK_Dim_Player_Dim_Position] -- Menjamo ovu liniju&#xA;END;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM sysobjects&#xA;&#x9;WHERE id = OBJECT_ID(N'Dim_Position')) -- Menjamo naziv tabele&#xA;BEGIN&#xA;&#x9;-- KOMANDA ZA DROP TABLE&#xA;&#x9;IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[Dim_Position]') AND type in (N'U'))&#xA;&#x9;DROP TABLE [dbo].[Dim_Position]&#xA;&#xA;&#xA;&#x9;-- KOMANDA ZA CREATE TABLE&#xA;CREATE TABLE [dbo].[Dim_Position](&#xA;&#x9;[position_sid] [int] IDENTITY(1,1) NOT NULL,&#xA;&#x9;[position_name] [nvarchar](50),&#xA;&#x9;[position_code] [varchar](10) NOT NULL,&#xA;&#x9;[position_group] [varchar](10) NOT NULL,&#xA;PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[position_sid] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Dim_Position]  WITH CHECK ADD  CONSTRAINT [CHK_Position_Group] CHECK  (([position_group]='Midfield' OR [position_group]='Defender' OR [position_group]='Attack' OR [position_group]='Goalkeeper' OR [position_group] ='Missing'))&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Dim_Position] CHECK CONSTRAINT [CHK_Position_Group]&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;END&#xA;&#xA;&#xA;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
