      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{48255525-DF27-4D39-9F96-F9E61C00D4D5}"
          SQLTask:SqlStatementSource="&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;&#x9;WHERE CONSTRAINT_NAME = 'FK_Fact_Appearances_Dim_Club') -- Menjamo naziv Constraint-a&#xA;&#xA;BEGIN&#xA;&#x9;&#xA;&#x9;ALTER TABLE [dbo].[Fact_Appearances] DROP CONSTRAINT [FK_Fact_Appearances_Dim_Club] -- Menjamo ovu liniju&#xA;END;&#xA;&#xA;&#xA;&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;&#x9;WHERE CONSTRAINT_NAME = 'FK_Fact_Valuations_Dim_Club') -- Menjamo naziv Constraint-a&#xA;&#xA;BEGIN&#xA;&#x9;&#xA;&#x9;ALTER TABLE [dbo].[Fact_Valuations] DROP CONSTRAINT [FK_Fact_Valuations_Dim_Club] -- Menjamo ovu liniju&#xA;END;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM sysobjects&#xA;&#x9;WHERE id = OBJECT_ID(N'Dim_Club')) -- Menjamo naziv tabele&#xA;BEGIN&#xA;&#x9;-- KOMANDA ZA DROP TABLE&#xA;&#x9;IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[Dim_Club]') AND type in (N'U'))&#xA;&#x9;DROP TABLE [dbo].[Dim_Club]&#xA;&#xA;&#xA;&#x9;-- KOMANDA ZA CREATE TABLE&#xA;CREATE TABLE [dbo].[Dim_Club](&#xA;&#x9;[club_sid] [int] IDENTITY(1,1) NOT NULL,&#xA;&#x9;[club_id] [int] NULL,&#xA;&#x9;[name] [nvarchar](100) NOT NULL,&#xA;&#x9;[club_code] [varchar](70) NOT NULL,&#xA;&#x9;[country_sid] [int] NULL,&#xA;&#x9;[stadium_name] [nvarchar](100) NULL,&#xA;&#x9;[stadium_seats] [bigint] NULL,&#xA;&#x9;[coach_name] [nvarchar](100) NULL,&#xA;PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[club_sid] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;&#xA;INSERT INTO [dbo].[Dim_Club]&#xA;           ([club_id]&#xA;           ,[name]&#xA;           ,[club_code]&#xA;           ,[country_sid]&#xA;           ,[stadium_name]&#xA;           ,[stadium_seats]&#xA;           ,[coach_name])&#xA;     VALUES&#xA;           (-1,&#xA;&#x9;&#x9;   'Missing',&#xA;&#x9;&#x9;   'Missing',&#xA;&#x9;&#x9;   1,&#xA;&#x9;&#x9;   'Missing',&#xA;&#x9;&#x9;   0,&#xA;&#x9;&#x9;   'Missing')           &#xA;&#xA;&#xA;END&#xA;&#xA;&#xA;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
