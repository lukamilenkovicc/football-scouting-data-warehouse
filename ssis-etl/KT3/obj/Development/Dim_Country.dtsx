      DTS:ObjectName="DROP and CREATE DimCountry"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{48255525-DF27-4D39-9F96-F9E61C00D4D5}"
          SQLTask:SqlStatementSource="&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;&#x9;WHERE CONSTRAINT_NAME = 'FK_Dim_Club_Dim_Country') -- Menjamo naziv Constraint-a&#xA;&#xA;BEGIN&#xA;&#x9;&#xA;&#x9;ALTER TABLE [dbo].[Dim_Club] DROP CONSTRAINT [FK_Dim_Club_Dim_Country] -- Menjamo ovu liniju&#xA;END;&#xA;&#xA;&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM INFORMATION_SCHEMA.REFERENTIAL_CONSTRAINTS&#xA;&#x9;WHERE CONSTRAINT_NAME = 'FK_Dim_Competition_Dim_Country') -- Menjamo naziv Constraint-a&#xA;&#xA;BEGIN&#xA;&#x9;&#xA;&#x9;ALTER TABLE [dbo].[Dim_Competition] DROP CONSTRAINT [FK_Dim_Competition_Dim_Country] -- Menjamo ovu liniju&#xA;END;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM sysobjects&#xA;&#x9;WHERE id = OBJECT_ID(N'Dim_Country')) -- Menjamo naziv tabele&#xA;BEGIN&#xA;&#x9;-- KOMANDA ZA DROP TABLE&#xA;&#x9;IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[Dim_Country]') AND type in (N'U'))&#xA;&#x9;DROP TABLE [dbo].[Dim_Country]&#xA;&#xA;&#xA;&#x9;-- KOMANDA ZA CREATE TABLE&#xA;&#x9;CREATE TABLE [dbo].[Dim_Country](&#xA;&#x9;[country_sid] [int] IDENTITY(1,1) NOT NULL,&#xA;&#x9;[country_id] [int] NULL,&#xA;&#x9;[country_name] [nvarchar](80) NOT NULL,&#xA;&#x9;[confederation] [varchar](20) NOT NULL,&#xA;PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[country_sid] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Dim_Country]  WITH CHECK ADD  CONSTRAINT [CHK_Country_Confederation] CHECK  (([confederation]='amerika' OR [confederation]='afrika' OR [confederation]='asien' OR [confederation]='europa' OR [confederation]='Missing'))&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Dim_Country] CHECK CONSTRAINT [CHK_Country_Confederation]&#xA;&#xA;&#xA;INSERT INTO [dbo].[Dim_Country]&#xA;           ([country_id]&#xA;           ,[country_name]&#xA;           ,[confederation])&#xA;     VALUES&#xA;           (-1,&#xA;           'Missing',&#xA;&#x9;&#x9;   'Missing')&#xA;&#xA;&#xA;END&#xA;&#xA;&#xA;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
