      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{48255525-DF27-4D39-9F96-F9E61C00D4D5}"
          SQLTask:SqlStatementSource="&#xA;IF EXISTS (&#xA;&#x9;SELECT * FROM sys.key_constraints&#xA;&#x9;WHERE name = 'UQ_Fact_Appearances' AND parent_object_id = OBJECT_ID('dbo.Fact_Appearances')&#xA;&#x9;)&#xA;BEGIN&#xA;&#x9;ALTER TABLE [dbo].[Fact_Appearances] DROP CONSTRAINT [UQ_Fact_Appearances]&#xA;END&#xA;&#xA;&#xA;&#xA;&#xA;IF EXISTS&#xA;&#x9;(SELECT *&#xA;&#x9;FROM sysobjects&#xA;&#x9;WHERE id = OBJECT_ID(N'Fact_Appearances')) -- Menjamo naziv tabele&#xA;&#xA;BEGIN&#xA;&#x9;-- KOMANDA ZA DROP TABLE&#xA;&#x9;IF  EXISTS (SELECT * FROM sys.objects WHERE object_id = OBJECT_ID(N'[dbo].[Fact_Appearances]') AND type in (N'U'))&#xA;&#x9;DROP TABLE [dbo].[Fact_Appearances]&#xA;&#xA;&#xA;&#x9;-- KOMANDA ZA CREATE TABLE&#xA;CREATE TABLE [dbo].[Fact_Appearances](&#xA;&#x9;[appearance_id] [int] IDENTITY(1,1) NOT NULL,&#xA;&#x9;[date_sid] [int] NOT NULL,&#xA;&#x9;[player_sid] [int] NOT NULL,&#xA;&#x9;[club_sid] [int] NOT NULL,&#xA;&#x9;[competition_sid] [int] NOT NULL,&#xA;&#x9;[goals] [int] NULL,&#xA;&#x9;[assists] [int] NULL,&#xA;&#x9;[minutes_played] [int] NULL,&#xA; CONSTRAINT [PK__Fact_App__4BCC8ECD64F0B8DC] PRIMARY KEY CLUSTERED &#xA;(&#xA;&#x9;[appearance_id] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY],&#xA; CONSTRAINT [UQ_Fact_Appearances] UNIQUE NONCLUSTERED &#xA;(&#xA;&#x9;[date_sid] ASC,&#xA;&#x9;[player_sid] ASC,&#xA;&#x9;[club_sid] ASC,&#xA;&#x9;[competition_sid] ASC&#xA;)WITH (PAD_INDEX = OFF, STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON, OPTIMIZE_FOR_SEQUENTIAL_KEY = OFF) ON [PRIMARY]&#xA;) ON [PRIMARY]&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Fact_Appearances] ADD  CONSTRAINT [DF__Fact_Appe__goals__3B75D760]  DEFAULT ((0)) FOR [goals]&#xA;&#xA;ALTER TABLE [dbo].[Fact_Appearances] ADD  CONSTRAINT [DF__Fact_Appe__assis__3C69FB99]  DEFAULT ((0)) FOR [assists]&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Fact_Appearances] ADD  CONSTRAINT [DF__Fact_Appe__minut__3D5E1FD2]  DEFAULT ((0)) FOR [minutes_played]&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Fact_Appearances]  WITH CHECK ADD  CONSTRAINT [FK_Fact_Appearances_Dim_Competition] FOREIGN KEY([competition_sid])&#xA;REFERENCES [dbo].[Dim_Competition] ([competition_sid])&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Fact_Appearances] CHECK CONSTRAINT [FK_Fact_Appearances_Dim_Competition]&#xA;&#xA;ALTER TABLE [dbo].[Fact_Appearances]  WITH CHECK ADD  CONSTRAINT [FK_Fact_Appearances_Dim_Date] FOREIGN KEY([date_sid])&#xA;REFERENCES [dbo].[Dim_Date] ([date_sid])&#xA;&#xA;&#xA;ALTER TABLE [dbo].[Fact_Appearances] CHECK CONSTRAINT [FK_Fact_Appearances_Dim_Date]&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;END&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
